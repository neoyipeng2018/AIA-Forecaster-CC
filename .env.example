# LLM Configuration
# Uses langchain-openai (ChatOpenAI). Accepts "provider/model-name" or just "model-name".
# The provider prefix is stripped before passing to ChatOpenAI.
# Examples:
#   gpt-4o
#   openai/o3
#   deepseek/deepseek-chat
LLM_MODEL=gpt-4o
OPENAI_API_KEY=

# Cerebras Fallback (optional)
# If set, Cerebras is used as a fallback when the primary LLM fails.
# Get a key at https://cloud.cerebras.ai/
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama-4-scout-17b-16e-instruct

# Forecaster Settings
NUM_AGENTS=10
MAX_SEARCH_ITERATIONS=5
PLATT_ALPHA=1.7320508075688772

# Default Currency Pair
DEFAULT_PAIR=USDJPY

# Storage
DB_PATH=data/forecasts/forecasts.db

# Company Extensions
# Add API keys for custom data sources in company/ here.
# These are only used if you have a company/ package with matching connectors.
# BLOOMBERG_API_KEY=
# REFINITIV_API_KEY=
# INTERNAL_NEWS_API_URL=
